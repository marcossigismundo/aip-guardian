# =============================================================================
# AIP Integrity Guardian — Environment Configuration
# =============================================================================
# Copy this file to .env and update with your values:
#   cp .env.example .env
#
# IMPORTANT: You MUST change GUARDIAN_SECRET_KEY, GUARDIAN_API_TOKEN, and
# POSTGRES_PASSWORD before running in production. The application will
# refuse to start with default values unless GUARDIAN_DEBUG=true.

# --- Application ---
GUARDIAN_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
GUARDIAN_DEBUG=true
GUARDIAN_ALLOWED_HOSTS=localhost,127.0.0.1,guardian.example.com
GUARDIAN_API_TOKEN=change-me-generate-a-secure-token
GUARDIAN_LOG_LEVEL=INFO

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql+asyncpg://guardian:password@localhost:5432/guardian_db
POSTGRES_PASSWORD=change-me-strong-database-password

# --- Database Pool ---
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# --- Celery (Redis) ---
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1
CELERY_CONCURRENCY=4

# --- HMAC Key (choose ONE method) ---
# Option A: Direct key (development only)
GUARDIAN_HMAC_KEY=your-secret-key-here
# Option B: Key file (production recommended)
# GUARDIAN_HMAC_KEY_FILE=/etc/guardian/hmac.key

# --- Archivematica Storage Service ---
ARCHIVEMATICA_SS_URL=http://localhost:8000
ARCHIVEMATICA_SS_USER=admin
ARCHIVEMATICA_SS_API_KEY=your-api-key
ARCHIVEMATICA_STORAGE_PATH=/var/archivematica/sharedDirectory

# --- RFC 3161 Timestamp Authority ---
GUARDIAN_TSA_URL=https://freetsa.org/tsr
GUARDIAN_TSA_FALLBACK_URL=https://timestamp.digicert.com

# --- Notifications ---
GUARDIAN_ADMIN_EMAIL=admin@example.com
GUARDIAN_SMTP_HOST=localhost
GUARDIAN_SMTP_PORT=587
GUARDIAN_SMTP_USER=
GUARDIAN_SMTP_PASSWORD=
GUARDIAN_WEBHOOK_URL=

# --- Verification Schedule ---
GUARDIAN_FIXITY_SCHEDULE_CRON=0 2 * * 0
GUARDIAN_ANCHOR_SCHEDULE_CRON=0 23 * * *
GUARDIAN_CHAIN_VERIFY_CRON=0 3 * * 1
