# =============================================================================
# Setup Wizard
# =============================================================================

msgid "setup_title"
msgstr "Setup Wizard"

msgid "setup_welcome"
msgstr "Welcome to AIP Integrity Guardian"

msgid "setup_welcome_desc"
msgstr "This wizard will guide you through the initial configuration of your Guardian instance."

msgid "setup_step1_title"
msgstr "Database Connection"

msgid "setup_step1_desc"
msgstr "Configure the PostgreSQL database connection. Guardian uses PostgreSQL to store AIP status, audit logs, and HMAC records."

msgid "setup_step2_title"
msgstr "Redis Connection"

msgid "setup_step2_desc"
msgstr "Configure the Redis connection for Celery task queue. Redis is used as the message broker for background task processing."

msgid "setup_step3_title"
msgstr "Archivematica Integration"

msgid "setup_step3_desc"
msgstr "Connect to your Archivematica Storage Service instance. Guardian will use this connection to discover and access AIPs."

msgid "setup_step4_title"
msgstr "HMAC Key Configuration"

msgid "setup_step4_desc"
msgstr "Set up the HMAC key used to sign AIP manifests. This key protects manifest files from tampering."

msgid "setup_step5_title"
msgstr "Verification Schedule"

msgid "setup_step5_desc"
msgstr "Configure the schedule for automated fixity checks, HMAC verification, and external anchoring."

msgid "setup_step6_title"
msgstr "Notifications"

msgid "setup_step6_desc"
msgstr "Set up email and webhook notifications for integrity alerts. You will be notified when corruption is detected."

msgid "setup_step7_title"
msgstr "Review & Finish"

msgid "setup_step7_desc"
msgstr "Review your configuration and complete the setup. You can change these settings later from the Settings page."

msgid "setup_test_connection"
msgstr "Test Connection"

msgid "setup_connection_success"
msgstr "Connection successful"

msgid "setup_connection_failed"
msgstr "Connection failed"

msgid "setup_generate_key"
msgstr "Generate Key"

msgid "setup_import_key"
msgstr "Import Key"

msgid "setup_skip_step"
msgstr "Skip This Step"

msgid "setup_finish"
msgstr "Finish Setup"

msgid "setup_complete"
msgstr "Setup Complete"

msgid "setup_complete_desc"
msgstr "Guardian has been configured successfully. You can now start monitoring your AIPs."

msgid "setup_go_dashboard"
msgstr "Go to Dashboard"

