# =============================================================================
# Asistente de Configuracion
# =============================================================================

msgid "setup_title"
msgstr "Asistente de Configuracion"

msgid "setup_welcome"
msgstr "Bienvenido a AIP Integrity Guardian"

msgid "setup_welcome_desc"
msgstr "Este asistente le guiara a traves de la configuracion inicial de su instancia de Guardian."

msgid "setup_step1_title"
msgstr "Conexion a la Base de Datos"

msgid "setup_step1_desc"
msgstr "Configure la conexion a la base de datos PostgreSQL. Guardian utiliza PostgreSQL para almacenar el estado de los AIPs, registros de auditoria y registros HMAC."

msgid "setup_step2_title"
msgstr "Conexion a Redis"

msgid "setup_step2_desc"
msgstr "Configure la conexion a Redis para la cola de tareas Celery. Redis se utiliza como intermediario de mensajes para el procesamiento de tareas en segundo plano."

msgid "setup_step3_title"
msgstr "Integracion con Archivematica"

msgid "setup_step3_desc"
msgstr "Conectese a su instancia del Servicio de Almacenamiento de Archivematica. Guardian usara esta conexion para descubrir y acceder a los AIPs."

msgid "setup_step4_title"
msgstr "Configuracion de Clave HMAC"

msgid "setup_step4_desc"
msgstr "Configure la clave HMAC utilizada para firmar los manifiestos de los AIPs. Esta clave protege los archivos de manifiesto contra manipulacion."

msgid "setup_step5_title"
msgstr "Programacion de Verificaciones"

msgid "setup_step5_desc"
msgstr "Configure la programacion para las verificaciones automaticas de fijeza, verificacion HMAC y anclaje externo."

msgid "setup_step6_title"
msgstr "Notificaciones"

msgid "setup_step6_desc"
msgstr "Configure las notificaciones por correo electronico y webhook para alertas de integridad. Sera notificado cuando se detecte corrupcion."

msgid "setup_step7_title"
msgstr "Revisar y Finalizar"

msgid "setup_step7_desc"
msgstr "Revise su configuracion y complete la instalacion. Puede cambiar estos ajustes mas tarde desde la pagina de Configuracion."

msgid "setup_test_connection"
msgstr "Probar Conexion"

msgid "setup_connection_success"
msgstr "Conexion exitosa"

msgid "setup_connection_failed"
msgstr "Conexion fallida"

msgid "setup_generate_key"
msgstr "Generar Clave"

msgid "setup_import_key"
msgstr "Importar Clave"

msgid "setup_skip_step"
msgstr "Omitir Este Paso"

msgid "setup_finish"
msgstr "Finalizar Configuracion"

msgid "setup_complete"
msgstr "Configuracion Completa"

msgid "setup_complete_desc"
msgstr "Guardian ha sido configurado exitosamente. Ahora puede comenzar a monitorear sus AIPs."

msgid "setup_go_dashboard"
msgstr "Ir al Panel de Control"

